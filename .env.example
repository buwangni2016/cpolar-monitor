# cpolar-monitor configuration
# Copy this file to .env and fill in your values

# cpolar account
CPOLAR_EMAIL=your-email@example.com
CPOLAR_PASSWORD=your-password

# Telegram Bot
TELEGRAM_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# Optional: check interval in seconds (default: 600 = 10min)
# CHECK_INTERVAL=600

# Optional: Telegram long polling timeout (default: 30)
# TELEGRAM_POLL_TIMEOUT=30

# Note: cpolar login page (/login) may return 404 due to website redesign.
# The script will still try to POST to /login for authentication.
# If login fails, check https://dashboard.cpolar.com/login manually.
