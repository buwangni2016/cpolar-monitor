# cpolar account
CPOLAR_EMAIL=your-email@example.com
CPOLAR_PASSWORD=your-password

# Telegram Bot
TELEGRAM_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# Optional: check interval in seconds (default: 600)
# CHECK_INTERVAL=600

# Optional: Telegram poll timeout in seconds (default: 30)
# TELEGRAM_POLL_TIMEOUT=30

# Optional: watchdog memory limit in MB (default: 50)
# MEMORY_LIMIT_MB=50
